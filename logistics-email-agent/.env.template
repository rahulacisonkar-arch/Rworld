# ==============================================================================
# Enterprise Logistics Email AI Agent - Environment Configuration Template
# ==============================================================================

# --- Application ---
LOG_LEVEL=INFO
DEBUG=true

# --- Database Configurations ---
# Local database for agent logs, cache, and state
DB_URL=sqlite:///agent.db

# Logistics Command Center (shipping-portal) MySQL Connection
PORTAL_DB_HOST=127.0.0.1
PORTAL_DB_PORT=3306
PORTAL_DB_NAME=artee_shipping
PORTAL_DB_USER=root
PORTAL_DB_PASS=

# --- AI LLM Connections ---
# Recommend pointing to the local headroom proxy: http://localhost:8787/v1
# or direct cloud services (OpenAI, Anthropic, Gemini, Nvidia)
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=http://localhost:8787/v1
OPENAI_MODEL=google/gemini-2.5-pro

# --- Email Server Polling ---
# Configuration for IMAP message fetching
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_USERNAME=logistics@example.com
EMAIL_PASSWORD=app_specific_password_here
EMAIL_CHECK_INTERVAL_SEC=60

# Mock Inbox Folder (for offline testing/demo)
# Set this to enable reading mock email files (.eml or .txt) from a folder
MOCK_INBOX_DIR=./mock_inbox

# --- SMTP Outgoing Email ---
SMTP_SERVER=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=shipping@arteefabrics.com

# --- Third-party Webhooks ---
# Replace the values below with your actual webhook URLs
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url_here
TEAMS_WEBHOOK_URL=your_teams_incoming_webhook_url_here

# --- Automated Rules ---
# If true, high-confidence (e.g. >95%) error-free drafts are sent directly to label generation
ENABLE_AUTO_LABEL=false
