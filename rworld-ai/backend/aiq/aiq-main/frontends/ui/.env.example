# =============================================================================
# AIQ Blueprint UI - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# =============================================================================
# Backend Configuration
# =============================================================================
# Backend URL - runtime configurable (no rebuild needed for containers)
# BACKEND_URL=http://localhost:8000

# =============================================================================
# Authentication
# =============================================================================
# Authentication is DISABLED by default. The app works with "Default User"
# and no login is required.
#
# To enable OAuth authentication, set REQUIRE_AUTH=true and configure
# the OAuth provider settings below.
# REQUIRE_AUTH=true

# NextAuth configuration (required when REQUIRE_AUTH=true)
# Generate secret with: openssl rand -base64 32
#
# IMPORTANT: NEXTAUTH_URL determines cookie security:
#   - http://...  → non-secure cookies (works over HTTP)
#   - https://... → secure cookies only (required for HTTPS)
#
# For reverse proxy setups (TLS terminated at proxy), set NEXTAUTH_URL
# to the external HTTPS URL, not the internal HTTP URL.
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Optional: Explicit cookie security override (rarely needed)
# SECURE_COOKIES=true

# Session and token lifetime tuning (optional)
#
# Session max age in hours (applies to both NextAuth session and idToken cookie).
# Default: 24. Both MUST stay aligned to prevent stale-credential bugs.
# SESSION_MAX_AGE_HOURS=24
#
# Minutes before token expiry to trigger proactive refresh.
# Default: 5. For deployments with long-running jobs (deep research runs
# 20-40+ minutes), set to 30 to prevent mid-job 401 errors.
# TOKEN_REFRESH_BUFFER_MINUTES=5

# =============================================================================
# OAuth Provider (required when REQUIRE_AUTH=true)
# =============================================================================
# Configure your OIDC-compatible identity provider (Keycloak, Auth0, Okta, etc.)
#
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/api/auth/callback/oauth

# OAuth issuer - enables OIDC auto-discovery (recommended)
# OAUTH_ISSUER=https://your-provider.example.com

# OAuth endpoints (optional if OAUTH_ISSUER is set for auto-discovery)
# OAUTH_AUTH_URL=https://your-provider.example.com/authorize
# OAUTH_TOKEN_URL=https://your-provider.example.com/token
# OAUTH_USERINFO_URL=https://your-provider.example.com/userinfo

# =============================================================================
# File Upload Configuration
# =============================================================================
# These settings control file upload validation in the knowledge layer.
# Values should match backend limits for consistent user experience.

# Accepted file extensions (comma-separated, include leading dots)
# FILE_UPLOAD_ACCEPTED_TYPES=.pdf,.txt,.md,.docx,.pptx

# Maximum total file size in MB
# FILE_UPLOAD_MAX_SIZE_MB=100

# Maximum number of files per session
# FILE_UPLOAD_MAX_FILE_COUNT=10

# Hours after upload before files may expire on the backend (0 = no expiry shown),
#this should ideally match TTL of the files on the backend (e.g. 12 hours)
# FILE_EXPIRATION_CHECK_INTERVAL_HOURS=0
