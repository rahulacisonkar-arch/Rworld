{
  "name": "aiq-blueprint-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names \",next\" \"npm run dev:proxy\" \"npm run dev:next\"",
    "dev:proxy": "node server.js",
    "dev:next": "next dev --turbopack -p 3001",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "TZ=UTC vitest --no-watch",
    "test:watch": "TZ=UTC vitest",
    "test:ci": "TZ=UTC vitest run --coverage",
    "ci:local": "./scripts/ci-check.sh",
    "ci:quick": "./scripts/ci-check.sh --quick",
    "ci:fast": "./scripts/ci-check.sh --no-clean",
    "prepare": "husky"
  },
  "dependencies": {
    "@nvidia/foundations-react-core": "^0.600.0",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/postcss": "^4.1.18",
    "http-proxy": "^1.18.1",
    "marked": "^16.4.2",
    "next": "^16.1.1",
    "next-auth": "^4.24.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "5.9.3",
    "zod": "^3.24.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.2.0",
    "@mswjs/data": "^0.16.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "15.2.3",
    "happy-dom": "^20.3.4",
    "husky": "^9.1.7",
    "msw": "^2.12.7",
    "postcss": "^8.4.21",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tailwindcss": "^4.0.0",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
