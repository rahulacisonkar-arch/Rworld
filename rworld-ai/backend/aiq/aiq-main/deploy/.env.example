# AI-Q Blueprint - Environment Configuration
#
# Copy to .env and set your values:
#   cp deploy/.env.example deploy/.env

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
PYTHONWARNINGS=ignore
AIQ_DEV_ENV=cli

# -----------------------------------------------------------------------------
# API Keys (required for core functionality)
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=


# Web search (Required)
TAVILY_API_KEY=

# Paper search (Optional)
# SERPER_API_KEY=   # to enable, set API key and update the relevant config in configs/ directory


# -----------------------------------------------------------------------------
# Job store (async jobs)
# SQLite: sqlite+aiosqlite:///./data/jobs.db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/aiq_jobs
# -----------------------------------------------------------------------------
# NAT_JOB_STORE_DB_URL=
# NAT_CONFIG_FILE=
# NAT_DASK_SCHEDULER_ADDRESS=
# Reduce Dask log noise (optional)
DASK_DISTRIBUTED__LOGGING__DISTRIBUTED=warning

# -----------------------------------------------------------------------------
# Checkpoint DB (LangGraph state)
# SQLite: ./checkpoints.db  |  PostgreSQL: postgresql://user:pass@host:5432/aiq_checkpoints
# -----------------------------------------------------------------------------
# AIQ_CHECKPOINT_DB=

# -----------------------------------------------------------------------------
# Summary DB (document summaries for agents)
# SQLite: sqlite+aiosqlite:///./summaries.db  |  PostgreSQL: postgresql+psycopg://...
# -----------------------------------------------------------------------------
# AIQ_SUMMARY_DB=

# -----------------------------------------------------------------------------
# Observability / Tracing (optional)
# See docs/source/deployment/observability.md for setup guides.
# -----------------------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=aiq-research
# WANDB_API_KEY=

# -----------------------------------------------------------------------------
# Evaluation (optional)
# -----------------------------------------------------------------------------
# JINA_API_KEY=

# -----------------------------------------------------------------------------
# Frontend File Upload Configuration
# -----------------------------------------------------------------------------
# These settings control file upload validation in the knowledge layer.
# Values should match backend limits for consistent user experience.

# Accepted file extensions (comma-separated, include leading dots).
# Default matches LlamaIndex backend. For Foundational RAG, add .pptx:
#   FILE_UPLOAD_ACCEPTED_TYPES=.pdf,.docx,.pptx,.txt,.md
FILE_UPLOAD_ACCEPTED_TYPES=.pdf,.docx,.txt,.md

# Maximum total file size in MB
FILE_UPLOAD_MAX_SIZE_MB=100

# Maximum number of files per session
FILE_UPLOAD_MAX_FILE_COUNT=10

# Hours after upload before files may expire on the backend (0 = no expiry shown),
#this should ideally match TTL of the files on the backend (e.g. 12 hours)
FILE_EXPIRATION_CHECK_INTERVAL_HOURS=0

# -----------------------------------------------------------------------------
# Embedding Model Environment Variables (optional, NVIDIA hosted models are used by default)
# -----------------------------------------------------------------------------
# AIQ_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2
# AIQ_EMBED_BASE_URL=https://integrate.api.nvidia.com/v1
#
# VLM Model Environment Variables (optional, NVIDIA hosted models are used by default)
# AIQ_VLM_MODEL=nvidia/nemotron-nano-12b-v2-vl
# AIQ_VLM_BASE_URL=https://integrate.api.nvidia.com/v1
#
# Image Extraction Environment Variables (optional)
# AIQ_EXTRACT_TABLES=false
# AIQ_EXTRACT_IMAGES=false
# AIQ_EXTRACT_CHARTS=false
#
# -----------------------------------------------------------------------------
# RAG Server and Ingestor URLs (required for knowledge layer)
# -----------------------------------------------------------------------------

# RAG_SERVER_URL=http://localhost:8081/v1
# RAG_INGEST_URL=http://localhost:8082/v1


# -----------------------------------------------------------------------------
# Frontend (UI) runtime configuration (Docker Compose)
# -----------------------------------------------------------------------------
# These variables are consumed by docker-compose.yaml.
# The compose files map them into the UI container as REQUIRE_AUTH and BACKEND_URL.

# Set to true to require OAuth login. False (default) uses a default user.
# REQUIRE_AUTH=false

# Backend URL used by the UI container.
# BACKEND_URL=http://aiq-agent:8000


# -----------------------------------------------------------------------------
# Backend configuration (Docker Compose)
# -----------------------------------------------------------------------------
# Workflow config file used by the backend server in Docker Compose.
# The compose stacks mount `configs/` into the container at `/app/configs`.
#
# Examples:
# - /app/configs/config_web_default_llamaindex.yml
# - /app/configs/config_web_frag.yml
# BACKEND_CONFIG=
